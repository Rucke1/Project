<!DOCTYPE html>
<html lang="en">
<head>
   <meta charset="utf-8">
   <meta name="viewport" content="width=device-width, initial-scale=1.0">
   <title>UHD Student Information Form</title>
   
   <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
   
   <link rel="stylesheet" href="style.css">
</head>
<body class="bg-light">

   <div class="container py-5">
      <div class="row justify-content-center">
         <div class="col-lg-8">
            
            <header class="text-center mb-5">
               <h1 class="display-5 text-uhd-blue">Student Registration Portal</h1>
               <p class="lead text-muted">University of Houston-Downtown Practice Form</p>
            </header>

            <main class="card shadow-sm border-0">
               <div class="card-body p-4 p-md-5">
                  <form method="post" action="http://randyconnolly.com/tests/process.php">
                     
                     <section class="mb-5">
                        <h2 class="h5 border-bottom pb-2 mb-4 text-uhd-red">Personal Details</h2>
                        <div class="row g-3">
                           <div class="col-md-6">
                              <label for="firstName" class="form-label">First Name</label>
                              <input type="text" id="firstName" name="firstName" class="form-control" required>
                           </div>
                           <div class="col-md-6">
                              <label for="lastName" class="form-label">Last Name</label>
                              <input type="text" id="lastName" name="lastName" class="form-control" required>
                           </div>
                           <div class="col-md-6">
                              <label for="birthDate" class="form-label">Birth Date</label>
                              <input type="date" id="birthDate" name="birthDate" class="form-control">
                           </div>
                           <div class="col-md-6">
                              <label for="phone" class="form-label">Phone Number</label>
                              <input type="tel" id="phone" name="phone" class="form-control" placeholder="713-555-0123">
                           </div>
                        </div>
                     </section>

                     <section class="mb-5">
                        <h2 class="h5 border-bottom pb-2 mb-4 text-uhd-red">Academic Information</h2>
                        <div class="mb-3 form-check">
                           <input type="checkbox" id="transfer" name="transfer" value="yes" class="form-check-input">
                           <label for="transfer" class="form-check-label">Transfer Student (if applicable)</label>
                        </div>
                        <div class="row g-3">
                           <div class="col-md-6">
                              <label for="level" class="form-label">Student Level</label>
                              <select id="level" name="level" class="form-select">
                                 <option value="undergrad">Undergraduate</option>
                                 <option value="grad">Graduate</option>
                              </select>
                           </div>
                           <div class="col-md-6">
                              <label for="major" class="form-label">Major</label>
                              <input type="text" id="major" name="major" class="form-control" placeholder="e.g., Computer Science">
                           </div>
                           <div class="col-12">
                              <label for="gradDate" class="form-label">Expected Graduation Date</label>
                              <input type="date" id="gradDate" name="gradDate" class="form-control">
                           </div>
                        </div>
                     </section>

                     <section class="mb-5">
                        <h2 class="h5 border-bottom pb-2 mb-4 text-uhd-red">Mailing Address</h2>
                        <div class="row g-3">
                           <div class="col-md-4">
                              <label for="addrNum" class="form-label">Address Number</label>
                              <input type="number" id="addrNum" name="addrNum" class="form-control">
                           </div>
                           <div class="col-md-8">
                              <label for="addrName" class="form-label">Street Name</label>
                              <input type="text" id="addrName" name="addrName" class="form-control">
                           </div>
                           <div class="col-md-6">
                              <label for="city" class="form-label">City</label>
                              <input type="text" id="city" name="city" class="form-control">
                           </div>
                           <div class="col-md-3">
                              <label for="state" class="form-label">State</label>
                              <input type="text" id="state" name="state" class="form-control" maxlength="2" placeholder="TX">
                           </div>
                           <div class="col-md-3">
                              <label for="zip" class="form-label">Zip Code</label>
                              <input type="text" id="zip" name="zip" class="form-control" pattern="[0-9]{5}">
                           </div>
                        </div>
                     </section>

                     <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-uhd btn-lg">Submit Registration</button>
                     </div>
                  </form>
               </div>
            </main>

            <footer class="text-center mt-4 text-muted small">
               <p>&copy; 2026 UHD Marilyn Davies College of Business Practice</p>
            </footer>

         </div>
      </div>
   </div>

   <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
style.css
CSS
/* UHD Custom Styles 
   Using System Font Stack (No external Google Fonts)
*/

body {
   font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
   line-height: 1.6;
}

h1, h2, .btn {
   font-weight: 700;
   text-transform: uppercase;
   letter-spacing: 0.02em;
}

/* Custom UHD Colors */
.text-uhd-blue {
   color: #002d72;
}

.text-uhd-red {
   color: #d42033;
}

.btn-uhd {
   background-color: #002d72;
   color: #ffffff;
   border: none;
   transition: background-color 0.3s ease;
}

.btn-uhd:hover {
   background-color: #d42033;
   color: #ffffff;
}

.card {
   border-top: 6px solid #d42033 !important;
}

/* Custom spacing for labels */
.form-label {
   font-weight: 600;
   font-size: 0.9rem;
   color: #495057;
}
